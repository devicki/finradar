# =============================================================================
# FinRadar — Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://finradar:finradar_dev@db:5432/finradar
DB_PASSWORD=finradar_dev

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# News APIs
# ---------------------------------------------------------------------------
NEWSAPI_KEY=your_newsapi_key_here
NEWSAPI_ENABLED=false  # true=dev only, false=production (free plan is not for commercial use)
POLYGON_API_KEY=your_polygon_key_here

# ---------------------------------------------------------------------------
# X (Twitter) API — pay-as-you-go at ~$0.005/read
# ---------------------------------------------------------------------------
# Disabled by default. To enable:
#   1. Set X_ENABLED=true
#   2. Fill X_BEARER_TOKEN from developer.x.com
#   3. (Optional) adjust X_TRACKED_ACCOUNTS and X_COLLECT_INTERVAL_MIN
# Task self-skips with NO API calls when X_ENABLED=false OR X_BEARER_TOKEN is empty.
X_ENABLED=false
X_BEARER_TOKEN=your_x_bearer_token_here
X_TRACKED_ACCOUNTS=markets,business,BloombergTV
X_COLLECT_INTERVAL_MIN=10
X_MAX_TWEETS_PER_ACCOUNT=50
X_MONTHLY_BUDGET_USD=30.0
X_COST_PER_READ_USD=0.0053  # $0.005 공시가보다 ~6% 높게 반영 (tweet field expansions 등 포함 실측치)

# ---------------------------------------------------------------------------
# Breaking-news alerts (Phase 3 Day 3) — push to Discord
# ---------------------------------------------------------------------------
# Disabled by default. To enable:
#   1. Create a Discord webhook (channel Settings → Integrations → Webhooks)
#   2. Set ALERTS_ENABLED=true, DISCORD_ENABLED=true, paste the URL below
# Triggers (OR): BREAKING flag  |  |sentiment| ≥ threshold AND cluster big  |  ticker watchlist hit
ALERTS_ENABLED=false
ALERTS_INTERVAL_MIN=5
ALERTS_HOURLY_CAP=50
ALERTS_LOOKBACK_MIN=60
ALERTS_MIN_ABS_SENTIMENT=0.7
ALERTS_MIN_CLUSTER_SIZE=3       # ko + others: strong-sentiment 하한
ALERTS_MIN_CLUSTER_SIZE_EN=2    # English 전용 하한 (EN RSS는 자연적 cluster 작음)
ALERTS_MAX_CLUSTER_SIZE=50      # upper bound — blocks Korean-news template chains
ALERTS_REQUIRE_SECTORS=true     # strong-sentiment trigger needs ≥1 LLM sector
ALERTS_TICKERS_WATCH=NVDA,AAPL,MSFT,TSLA,005930.KS,000660.KS
# Dual-signal gate (local FinBERT/KR-FinBert-SC + LLM) + rescue branch:
#   - Dual path requires BOTH |local| and |llm| >= ALERTS_MIN_ABS_SENTIMENT AND signs agree.
#   - Rescue path fires when |llm| alone >= ALERTS_LLM_RESCUE_THRESHOLD (stricter, since
#     cross-model check is bypassed). Cluster gates / sectors requirement still apply.
ALERTS_LLM_RESCUE_THRESHOLD=0.8
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Clustering (Phase 3) — connected-components over cosine + guards
# ---------------------------------------------------------------------------
# 아래 기본값들은 Korean 템플릿 기사의 과-클러스터링(무관한 기사 100+건 체인)을
# 없애도록 튜닝된 공격적 프로파일. 재조정 시 scripts/cluster_dryrun.py 로
# DB 쓰기 없이 새 파라미터 분포를 먼저 확인할 것.
#   CLUSTER_COSINE_THRESHOLD      : SQL KNN 베이스라인. cross-lang 페어에 바로 적용
#   CLUSTER_SAME_LANG_COSINE      : 같은 언어 페어에 적용하는 더 엄격한 하한
#   CLUSTER_TITLE_OVERLAP_MIN     : 공유 제목 토큰 최소 개수 (stopword 제거 후)
#   CLUSTER_TITLE_OVERLAP_RATIO   : shared_tokens / min(|A|,|B|) 하한
#   CLUSTER_MIN_BODY_JACCARD      : summary 2-shingle Jaccard 하한 (0 이면 비활성)
#   CLUSTER_APPLY_STOPWORDS       : KR/EN 금융 boilerplate stopword 필터링
CLUSTER_WINDOW_DAYS=7
CLUSTER_COSINE_THRESHOLD=0.80
CLUSTER_SAME_LANG_COSINE=0.85
CLUSTER_TITLE_OVERLAP_MIN=2
CLUSTER_TITLE_OVERLAP_RATIO=0.30
CLUSTER_MIN_BODY_JACCARD=0.15
CLUSTER_APPLY_STOPWORDS=true

# ---------------------------------------------------------------------------
# YouTube community posts — free (HTML scrape of ytInitialData, no API key)
# ---------------------------------------------------------------------------
# Enabled by default since it has zero cost. Each handle's /@<handle>/posts
# page is fetched on a smart 3-tier Beat schedule:
#   intensive 30 min  — KST 05-10 (US market close window)
#   regular   2 hours — KST 11-23 (daytime)
#   light     4 hours — KST 00-04 (overnight)
# Collector skips itself gracefully if YOUTUBE_ENABLED=false or channels empty.
YOUTUBE_ENABLED=true
YOUTUBE_CHANNELS=futuresnow            # comma-separated handles, no leading @
YOUTUBE_DEFAULT_LANGUAGE=ko            # ISO code applied to every scraped post

# ---------------------------------------------------------------------------
# AI - Cloud LLM
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

GROK_API_KEY=your_grok_api_key_here
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-3-mini-fast

# Which cloud LLM provider to use for summarization / translation
# Accepted values: anthropic | openai | grok
LLM_PROVIDER=anthropic

# ---------------------------------------------------------------------------
# AI - Local Models  (run on RTX 3080 Ti)
# ---------------------------------------------------------------------------
# Device for local inference: "cuda" or "cpu"
LOCAL_MODEL_DEVICE=cuda

# HuggingFace model IDs
SENTIMENT_MODEL_EN=ProsusAI/finbert
SENTIMENT_MODEL_KO=snunlp/KR-FinBert-SC
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ---------------------------------------------------------------------------
# Collection Schedule
# ---------------------------------------------------------------------------
# How often (in minutes) the Celery Beat scheduler triggers news collection
COLLECTION_INTERVAL_MINUTES=15

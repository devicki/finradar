# =============================================================================
# FinRadar — Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://finradar:finradar_dev@db:5432/finradar
DB_PASSWORD=finradar_dev

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# News APIs
# ---------------------------------------------------------------------------
NEWSAPI_KEY=your_newsapi_key_here
NEWSAPI_ENABLED=false  # true=dev only, false=production (free plan is not for commercial use)
POLYGON_API_KEY=your_polygon_key_here

# ---------------------------------------------------------------------------
# X (Twitter) API — pay-as-you-go at ~$0.005/read
# ---------------------------------------------------------------------------
# Disabled by default. To enable:
#   1. Set X_ENABLED=true
#   2. Fill X_BEARER_TOKEN from developer.x.com
#   3. (Optional) adjust X_TRACKED_ACCOUNTS and X_COLLECT_INTERVAL_MIN
# Task self-skips with NO API calls when X_ENABLED=false OR X_BEARER_TOKEN is empty.
X_ENABLED=false
X_BEARER_TOKEN=your_x_bearer_token_here
X_TRACKED_ACCOUNTS=markets,business,BloombergTV
X_COLLECT_INTERVAL_MIN=10
X_MAX_TWEETS_PER_ACCOUNT=50
X_MONTHLY_BUDGET_USD=30.0
X_COST_PER_READ_USD=0.0053  # $0.005 공시가보다 ~6% 높게 반영 (tweet field expansions 등 포함 실측치)

# ---------------------------------------------------------------------------
# AI - Cloud LLM
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

GROK_API_KEY=your_grok_api_key_here
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-3-mini-fast

# Which cloud LLM provider to use for summarization / translation
# Accepted values: anthropic | openai | grok
LLM_PROVIDER=anthropic

# ---------------------------------------------------------------------------
# AI - Local Models  (run on RTX 3080 Ti)
# ---------------------------------------------------------------------------
# Device for local inference: "cuda" or "cpu"
LOCAL_MODEL_DEVICE=cuda

# HuggingFace model IDs
SENTIMENT_MODEL_EN=ProsusAI/finbert
SENTIMENT_MODEL_KO=snunlp/KR-FinBert-SC
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ---------------------------------------------------------------------------
# Collection Schedule
# ---------------------------------------------------------------------------
# How often (in minutes) the Celery Beat scheduler triggers news collection
COLLECTION_INTERVAL_MINUTES=15
